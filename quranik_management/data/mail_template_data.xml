<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="email_template_quran_session_reminder" model="mail.template">
            <field name="name">Quranik: Session Reminder</field>
            <field name="model_id" ref="quranik_management.model_quran_session"/>
            <field name="subject">Your Quran Session: {{ object.start_datetime.strftime('%Y-%m-%d %H:%M') }}</field>
            <field name="email_from">{{ object.teacher_id.email }}</field>
            <field name="partner_to">{{ object.student_id.id }}</field>
            <field name="body_html" type="html">
                <div style="font-family: 'Lucid Grande', Ubuntu, Arial, Verdana, sans-serif; font-size: 14px;">
                    <p>Assalamu Alaikum / Hello <t t-out="object.student_id.name"/>,</p>
                    <p>This is a reminder for your Quran session with <strong><t t-out="object.teacher_id.name"/></strong>.</p>
                    <p><strong>Time:</strong> <t t-out="object.start_datetime"/></p>
                    <p><strong>Meeting Link:</strong> <a t-att-href="object.meeting_url" style="background-color: #875A7B; padding: 8px 16px; text-decoration: none; color: #fff; border-radius: 5px;">Join Class Here</a></p>
                    <hr/>
                    <p style="direction: rtl; text-align: right;">السلام عليكم <t t-out="object.student_id.name"/>،</p>
                    <p style="direction: rtl; text-align: right;">نذكركم بموعد حلقة القرآن مع الأستاذ <strong><t t-out="object.teacher_id.name"/></strong>.</p>
                    <p style="direction: rtl; text-align: right;"><strong>الرابط:</strong> <a t-att-href="object.meeting_url">اضغط هنا للانضمام</a></p>
                </div>
            </field>
        </record>

        <record id="email_template_session_report" model="mail.template">
    <field name="name">Quranik: Session Report &amp; Feedback</field>
    <field name="model_id" ref="model_quran_session"/>
    <field name="subject">Session Report - {{ object.start_datetime.strftime('%Y-%m-%d') }}</field>
    <field name="email_from">{{ object.teacher_id.email }}</field>
    <field name="partner_to">{{ object.student_id.id }}</field>
    <field name="body_html" type="html">
        <div style="font-family: Arial, sans-serif;">
            <p>Assalamu Alaikum,</p>
            <p>Your session is finished. Here is the summary:</p>
            <ul>
                <li><strong>Teacher:</strong> <t t-out="object.teacher_id.name"/></li>
                <li><strong>Progress:</strong> <t t-out="object.progress_details"/></li>
                <li><strong>Next Homework:</strong> <t t-out="object.homework"/></li>
            </ul>
            <p>Please take a moment to rate the session and the teacher:</p>
            <p>
                <a href="URL_DE_VOTRE_SURVEY_ODOO" 
                   style="background-color: #00A09D; padding: 10px; color: white; text-decoration: none; border-radius: 5px;">
                   Rate My Session
                </a>
            </p>
        </div>
    </field>
</record>
    </data>
</odoo>
