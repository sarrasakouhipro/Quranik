<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="module_category_quranik" model="ir.module.category">
            <field name="name">Quranik Management</field>
            <field name="sequence">10</field>
        </record>

        <record id="group_quranik_teacher" model="res.groups">
            <field name="name">Teacher</field>
            <field name="category_id" ref="module_category_quranik"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="rule_quran_session_teacher" model="ir.rule">
            <field name="name">Teachers see only their sessions</field>
            <field name="model_id" ref="model_quran_session"/>
            <field name="groups" eval="[(4, ref('group_quranik_teacher'))]"/>
            <field name="domain_force">[('teacher_id.user_id', '=', user.id)]</field>
        </record>
    </data>
</odoo>
