<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_quran_session" model="ir.actions.act_window">
            <field name="name">Sessions</field>
            <field name="res_model">quran.session</field>
            <field name="view_mode">calendar,tree,form,pivot,graph</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Planifiez votre première séance de Coran !
                </p>
            </field>
        </record>


        <record id="action_quran_teachers" model="ir.actions.act_window">
    <field name="name">Teachers</field>
    <field name="res_model">res.partner</field>
    <field name="view_mode">kanban,tree,form</field>
    <field name="domain">[('is_teacher', '=', True)]</field>
    <field name="context">{'default_is_teacher': True, 'default_customer_rank': 0}</field>
    <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">Create your first Teacher profile</p>
    </field>
</record>

<record id="action_quran_students" model="ir.actions.act_window">
    <field name="name">Students</field>
    <field name="res_model">res.partner</field>
    <field name="view_mode">kanban,tree,form</field>
    <field name="domain">[('is_student', '=', True)]</field>
    <field name="context">{'default_is_student': True, 'default_customer_rank': 1}</field>
    <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">Register your first Student</p>
    </field>
</record>
        
        <menuitem id="menu_quranik_root" 
                  name="Quranik" 
                  web_icon="base,static/description/icon.png" 
                  action="action_quran_session"
                  sequence="1"/>

        <menuitem id="menu_quranik_sessions_sub" 
                  name="Sessions" 
                  parent="menu_quranik_root" 
                  action="action_quran_session" 
                  sequence="10"/>

        <menuitem id="menu_quran_teachers" 
          name="Teachers" 
          parent="menu_quranik_root" 
          action="action_quran_teachers" 
          sequence="20"/>

<menuitem id="menu_quran_students" 
          name="Students" 
          parent="menu_quranik_root" 
          action="action_quran_students" 
          sequence="30"/>

        <menuitem id="menu_quran_programs" name="Programs" parent="menu_quranik_root" action="action_quran_program" sequence="40"/>
    </data>
</odoo>
