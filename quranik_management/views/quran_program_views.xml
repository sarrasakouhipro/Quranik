<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_quran_program_tree" model="ir.ui.view">
        <field name="name">quran.program.tree</field>
        <field name="model">quran.program</field>
        <field name="arch" type="xml">
            <tree string="Programs">
                <field name="name"/>
                <field name="audience"/>
                <field name="sessions_per_week"/>
                <field name="duration" widget="float_time"/>
                <field name="price"/>
            </tree>
        </field>
    </record>

    <record id="view_quran_program_form" model="ir.ui.view">
        <field name="name">quran.program.form</field>
        <field name="model">quran.program</field>
        <field name="arch" type="xml">
            <form string="Program">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="audience"/>
                            <field name="price"/>
                        </group>
                        <group>
                            <field name="sessions_per_week"/>
                            <field name="duration" widget="float_time"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_quran_program" model="ir.actions.act_window">
        <field name="name">Programs</field>
        <field name="res_model">quran.program</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
