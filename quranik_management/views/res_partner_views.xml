<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_partner_form_quranik" model="ir.ui.view">
            <field name="name">res.partner.form.quranik</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string="Quranik Profile" name="quranik_profile">
                        <group>
                            <group string="Identity Roles">
                                <field name="is_teacher"/>
                                <field name="is_student"/>
                            </group>
                            <group string="Account Status">
                                <field name="session_credits"/>
                                <field name="wallet_balance"/>
                            </group>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
