<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_partner_form_quranik" model="ir.ui.view">
            <field name="name">res.partner.form.quranik</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string="Quranik Profile" name="quranik_profile">
                        <group>
                            <group string="Roles">
                                <field name="is_teacher"/>
                                <field name="is_student"/>
                            </group>
                            <group string="Stats">
                                <field name="session_credits" attrs="{'invisible': [('is_student', '=', False)]}"/>
                                <field name="wallet_balance" attrs="{'invisible': [('is_teacher', '=', False)]}"/>
                            </group>
                        </group>
                        <group string="Teacher Settings" attrs="{'invisible': [('is_teacher', '=', False)]}">
                            <field name="is_english_speaker"/>
                            <field name="commission_rate"/>
                        </group>
                        <group string="Teacher Settings" attrs="{'invisible': [('is_teacher', '=', False)]}">
    <field name="user_id"/> <field name="is_english_speaker"/>
    <field name="quran_reading_ids" widget="many2many_tags"/>
    <field name="commission_rate"/>
</group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
