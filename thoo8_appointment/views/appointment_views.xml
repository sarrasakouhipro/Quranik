<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_appointment_form" model="ir.ui.view">
            <field name="name">thoo8.appointment.request.form</field>
            <field name="model">thoo8.appointment.request</field>
            <field name="arch" type="xml">
                <form string="Appointment Booking">
                    <header>
                        <button id="button_cancelled" name="action_cancelled" type="object" states="draft,confirmed"
                                string="Cancel Appointment" class="btn-danger" icon="fa-lock"
                                groups="thoo8_appointment.group_thoo8_appointment_manage,thoo8_appointment.group_thoo8_appointment_full_access"/>
                        <button id="button_confirmed" name="action_confirmed" type="object" states="draft"
                                string="Confirm Appointment" class="btn-primary" icon="fa-thumbs-up"
                                groups="thoo8_appointment.group_thoo8_appointment_manage,thoo8_appointment.group_thoo8_appointment_full_access"/>
                        <button id="button_completed" name="action_completed" type="object" states="confirmed"
                                string="Completed Appointment" class="btn-success" icon="fa-check-square-o"
                                groups="thoo8_appointment.group_thoo8_appointment_manage,thoo8_appointment.group_thoo8_appointment_full_access"/>
                        <button id="button_draft" name="action_draft" type="object" states="cancelled,confirmed,completed"
                                string="Set As Draft" class="btn-secondary" icon="fa-archive"
                                groups="thoo8_appointment.group_thoo8_appointment_manage,thoo8_appointment.group_thoo8_appointment_full_access"/>
                        <button id="button_open_assign_wizard" name="action_open_assign_wizard" type="object"
                                string="Assign To" class="btn-primary" icon="fa-user"
                                groups="thoo8_appointment.group_thoo8_appointment_manage,thoo8_appointment.group_thoo8_appointment_full_access,thoo8_appointment.group_thoo8_appointment_assign"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,completed"/>
                    </header>
                    <sheet>
                        <field name="use_schedule" invisible="1"/>
                        
                        <widget name="web_ribbon" title="Cancelled" bg_color="bg-danger"
                                attrs="{'invisible': [('state', '!=', 'cancelled')]}"/>
                        <widget name="web_ribbon" title="Completed" bg_color="bg-success"
                                attrs="{'invisible': [('state', '!=', 'completed')]}"/>

                        <div class="alert alert-danger text-center o_form_header" role="alert"
                            attrs="{'invisible': [('state', '!=', 'cancelled')]}">
                            <div>
                                <strong>Reason for cancellation:</strong>
                                <label for="cancel_reason" string=""/>
                                <field name="cancel_reason" required="0" readonly="1"/>
                                <label for="cancel_note" string=""/>
                                <field name="cancel_note" required="0" readonly="1"/>
                            </div>
                        </div>
                        <group>
                            <group>
                                <field name="name" readonly="1"/>
                                <field name="beneficiary_name"/>
                                <field name="id_card"/>
                                <field name="mobile"/>
                                <field name="mobile_other"/>
                            </group>
                            <group>
                                <field name="use_schedule" widget="boolean_toggle"/>
                                <field name="service_type_id"/>
                                <field name="department"/>
                                <field name="appointment_date" attrs="{'invisible': [('use_schedule', '=', True)]}"/>
                                <field name="slot_id"
                                       attrs="{'invisible': ['|', ('use_schedule', '=', False), ('slot_message','!=',False)],
                                               'readonly': [('slot_message','!=',False)]}"/>
                                <field name="slot_message" readonly="1" nolabel="0" class="text-danger" string=" "
                                       attrs="{'invisible': ['|', ('use_schedule', '=', False), ('slot_message','=',False)]}"/>
                                <field name="user_id" readonly="1"/>
                                <field name="appointment_end" invisible="1"/>
                                <field name="formatted_datetime_ar"/>
                                <field name="service_note" readonly="1" attrs="{'invisible': [('service_note', '=', False)]}" placeholder="No Note For This Appointment"/>
                            </group>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" groups="base.group_user"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="view_appointment_search" model="ir.ui.view">
            <field name="name">appointment.search</field>
            <field name="model">thoo8.appointment.request</field>
            <field name="arch" type="xml">
                <search string="Search">
                    <field name="id_card"/>
                    <field name="beneficiary_name"/>
                    <field name="name"/>
                    <field name="mobile"/>
                    <separator/>
                    <filter name="filter_state" string="State Confirmed" domain="[('state', '=', 'confirmed')]"/>
                    <filter name="filter_state" string="State Draft" domain="[('state', '=', 'draft')]"/>
                    <filter name="filter_state" string="State Cancelled" domain="[('state', '=', 'cancelled')]"/>
                    <filter name="filter_state" string="State Completed" domain="[('state', '=', 'completed')]"/>
                    <group expand="1" string="Group By">
                        <filter string="Department" name="grp_department" context="{'group_by':'department'}"/>
                        <filter string="Assign To" name="grp_user" context="{'group_by':'user_id'}"/>
                        <filter string="State" name="grp_state" context="{'group_by':'state'}"/>
                        <filter string="Date" name="grp_date" context="{'group_by':'appointment_date'}"/>
                    </group>
                    <searchpanel>
                        <field name="state" icon="fa-list" select="1" enable_counters="1" />
                        <field name="department" enable_counters="1" select="1"/>
                        <field name="service_type_id" icon="fa-bars" select="" enable_counters="1" />
                        <field name="user_id" icon="fa-user" select="1" enable_counters="1"/>
                    </searchpanel>
                </search>
            </field>
        </record>
        
        </data>
</odoo>
