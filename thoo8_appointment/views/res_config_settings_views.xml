<odoo>
    <data>
        <record id="view_res_config_settings_appointment" model="ir.ui.view">
            <field name="name">res.config.settings.appointment</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[hasclass('settings')]" position="inside">
                    <div class="app_settings_block" data-string="Appointment System" data-key="thoo8_appointment" string="Appointment System">
                        <h2>Appointment System</h2>

                        <div class="row mt16 o_settings_container" id="management">
                            <div class="col-12 col-lg-6 o_setting_box" >
                                <div class="o_setting_left_pane">
                                    <field name="stop_all_bookings"/>
                                </div>
                                <div class="o_setting_right_pane" id="stop_all_bookings">
                                    <label for="stop_all_bookings"/>
                                    <div class="text-danger">
                                        If enabled, no new appointment bookings will be accepted.
                                    </div>
                                </div>
                            </div>
                            <div class="col-xs-12 col-md-6 o_setting_box" id="stop_when_reached">
                                <div class="o_setting_left_pane">
                                    <field name="stop_when_reached"/>
                                </div>
                                <div class="o_setting_right_pane">
                                    <label for="stop_when_reached"/>
                                    <div class="text-muted">
                                        If enabled, appointment bookings will stop once the allowed number is reached.
                                    </div>
                                    <div id="max_daily_bookings" class="content-group" attrs="{'invisible': [('stop_when_reached', '=', False)]}">
                                        <field name="max_daily_bookings" attrs="{'invisible': [('stop_when_reached','=',False)]}"/>
                                        <div class="text-warning mb4">
                                            The allowed number of daily bookings via the portal. Employees can still create appointments via the internal system.
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row mt16 o_settings_container" id="management">
                            <!-- Enable verification mobile -->
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane">
                                    <field name="enable_mobile_verification"/>
                                </div>
                                <div class="o_setting_right_pane" id="enable_mobile_verification">
                                    <label for="enable_mobile_verification"/>
                                    <div class="text-muted">
                                        This option requires:
                                        <ul>
                                            <li>Installing and activating the <b>THOO8 SMS Gateway</b> module</li>
                                            <li>Selecting a default SMS Provider in the settings</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                            <!-- Enable verification mobile -->
                            <div class="col-12 col-lg-6 o_setting_box" >
                                <div class="o_setting_left_pane">
                                        <field name="enable_id_card_verification"/>
                                </div>
                                <div class="o_setting_right_pane" id="enable_id_card_verification">
                                    <label for="enable_id_card_verification"/>
                                    <div class="text-muted">
                                        <p>
                                            When enabled, this feature will validate both Saudi National ID numbers and Saudi Resident "Iqamah" ID numbers during appointment booking.
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </xpath>
            </field>
        </record>

        <record id="action_thoo8_appointment_config_settings_action" model="ir.actions.act_window">
            <field name="name">Appointment System Management</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">res.config.settings</field>
            <field name="view_id" ref="view_res_config_settings_appointment"/>
            <field name="view_mode">form</field>
            <field name="target">inline</field>
            <field name="context">{'module' : 'thoo8_appointment'}</field>
        </record>

        <menuitem id="configuration_appointment"
                  name="Configuration"
                  parent="menu_thoo8_settings"
                  action="action_thoo8_appointment_config_settings_action"
                  groups="thoo8_appointment.group_thoo8_appointment_full_access"
                  sequence="1"/>
    </data>
</odoo>